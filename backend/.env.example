# Variáveis de ambiente — AgroSemen Backend
# Copie este arquivo para .env e preencha os valores

# Banco de dados (PostgreSQL)
DATABASE_URL="postgresql://agrosemen:SENHA_AQUI@localhost:5432/agrosemen_prod"

# JWT
JWT_SECRET="troque-por-uma-string-longa-e-aleatoria-em-producao"
JWT_EXPIRES_IN="30d"

# Servidor
PORT=3000
HOST="0.0.0.0"
NODE_ENV="development"

# Upload de fotos
UPLOAD_DIR="/opt/agrosemen/uploads"
MAX_FILE_SIZE=10485760

# URL pública do servidor (para montar URLs de fotos)
PUBLIC_URL="http://163.176.47.4"
